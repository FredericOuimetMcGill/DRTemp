Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Written", " ", "by", " ", "Frederic", " ", "Ouimet", " ", 
    RowBox[{"(", 
     RowBox[{"November", " ", "2024"}], ")"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "SetDirectory", 
     "[", "\"\<C:\\\\Users\\\\oufr6443\\\\Dropbox\\\\Ouimet_Genest_projects\\\
\\DGKKO_2025_Dirichlet_regression_comparison\\\\DirichletReg-main\\\\real_\
data_application\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "the", " ", "necessary", " ", "functions"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"hatM", "[", 
      RowBox[{"xx_", ",", "b_", ",", "s_", ",", "y_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "n", ",", "d", ",", "u", ",", "v", ",", "kernelVec", ",", "designMat",
          ",", "W"}], "}"}], ",", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "xx", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"d", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"xx", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Calculate", " ", "kernel", " ", "vector"}], "*)"}], 
        RowBox[{"u", "=", 
         RowBox[{
          RowBox[{"s", "/", "b"}], "+", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"1", ",", "d"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"v", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"Total", "[", "s", "]"}]}], ")"}], "/", "b"}], "+", 
          "1"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"kernelVec", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"PDF", "[", 
            RowBox[{
             RowBox[{"DirichletDistribution", "[", 
              RowBox[{"Join", "[", 
               RowBox[{"u", ",", 
                RowBox[{"{", "v", "}"}]}], "]"}], "]"}], ",", 
             RowBox[{"xx", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Local", " ", "Linear", " ", "Estimation"}], "*)"}], 
        RowBox[{"designMat", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"{", "1", "}"}], ",", 
             RowBox[{
              RowBox[{"xx", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", "s"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"W", "=", 
         RowBox[{"DiagonalMatrix", "[", "kernelVec", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Return", "[", 
         RowBox[{"First", "[", 
          RowBox[{"LinearSolve", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Transpose", "[", "designMat", "]"}], ".", "W", ".", 
             "designMat"}], ",", 
            RowBox[{
             RowBox[{"Transpose", "[", "designMat", "]"}], ".", "W", ".", 
             "y"}]}], "]"}], "]"}], "]"}], ";"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"GEMAS", " ", "dataset"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Load", " ", "CSV", " ", "file", " ", "and", " ", "import", " ", "data"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<GEMAS.csv\>\"", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Remove", " ", "the", " ", "header", " ", "row", " ", "and", " ", 
     "filter", " ", "data"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"filteredData", "=", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Rest", "[", "data", "]"}], ",", 
       RowBox[{
        RowBox[{"And", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"NumericQ", "[", "#", "]"}], "&&", 
             RowBox[{"#", "=!=", "\"\<\>\""}], "&&", 
             RowBox[{"#", "=!=", "Null"}], "&&", 
             RowBox[{
              RowBox[{"Head", "[", "#", "]"}], "=!=", "Missing"}]}], "&"}], "/@", 
           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"{", 
              RowBox[{"15", ",", "16", ",", "17", ",", "25"}], "}"}], "]"}], 
            "]"}]}], ")"}]}], "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Extract", " ", "relevant", " ", "columns", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"15", ":", "sand_norm"}], ",", 
       RowBox[{"16", ":", "silt_norm"}], ",", 
       RowBox[{"17", ":", "clay_norm"}], ",", 
       RowBox[{"25", ":", "pH_CaCl2"}]}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"vectors", "=", 
     RowBox[{"filteredData", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"{", 
         RowBox[{"15", ",", "16", ",", "17", ",", "25"}], "}"}]}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Extract", " ", "xx", " ", "and", " ", "y", " ", "from", " ", "the", " ", 
     "given", " ", "vectors"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"xx", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"vectors", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"1", ";;", "2"}]}], "]"}], "]"}], ")"}], "/", "100"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"y", "=", 
     RowBox[{"vectors", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "4"}], "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"Optimal", " ", "b", " ", 
     RowBox[{"(", 
      RowBox[{"b_opt", "_LOOCV", " ", "from", " ", "R"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"b", "=", "0.0303333333333333"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"hatMFunction", "[", 
      RowBox[{"s1_", ",", "s2_"}], "]"}], ":=", 
     RowBox[{"hatM", "[", 
      RowBox[{"xx", ",", "b", ",", 
       RowBox[{"{", 
        RowBox[{"s1", ",", "s2"}], "}"}], ",", "y"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Measure", " ", "time", " ", "for", " ", "DensityPlot", " ", "and", " ", 
     "Plot3D"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"time", "=", 
     RowBox[{
      RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Create", " ", "density", " ", "plot"}], "*)"}], 
       RowBox[{
        RowBox[{"densityPlot", "=", 
         RowBox[{"DensityPlot", "[", 
          RowBox[{
           RowBox[{"Evaluate", "[", 
            RowBox[{"hatMFunction", "[", 
             RowBox[{"s1", ",", "s2"}], "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"s1", ",", "0", ",", "1"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"s2", ",", "0", ",", "1"}], "}"}], ",", 
           RowBox[{"RegionFunction", "->", 
            RowBox[{"Function", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"s1", ",", "s2"}], "}"}], ",", 
              RowBox[{
               RowBox[{"s1", "+", "s2"}], "<=", "1"}]}], "]"}]}], ",", 
           RowBox[{"PlotLegends", "->", 
            RowBox[{"Placed", "[", 
             RowBox[{
              RowBox[{"BarLegend", "[", 
               RowBox[{"Automatic", ",", 
                RowBox[{"LegendMarkerSize", "->", "300"}], ",", 
                RowBox[{"LabelStyle", "->", 
                 RowBox[{"Directive", "[", 
                  RowBox[{"FontSize", "->", "12"}], "]"}]}]}], "]"}], ",", 
              "Right"}], "]"}]}], ",", 
           RowBox[{"ColorFunction", "->", "\"\<Rainbow\>\""}], ",", 
           RowBox[{"Frame", "->", "True"}], ",", 
           RowBox[{"FrameLabel", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Style", "[", 
               RowBox[{"\"\<Sand\>\"", ",", 
                RowBox[{"FontSize", "->", "14"}]}], "]"}], ",", 
              RowBox[{"Style", "[", 
               RowBox[{"\"\<Silt\>\"", ",", 
                RowBox[{"FontSize", "->", "14"}]}], "]"}]}], "}"}]}], ",", 
           RowBox[{"TicksStyle", "->", 
            RowBox[{"Directive", "[", 
             RowBox[{"FontSize", "->", "12"}], "]"}]}], ",", 
           RowBox[{"LabelStyle", "->", 
            RowBox[{"Directive", "[", 
             RowBox[{"FontSize", "->", "12"}], "]"}]}]}], "]"}]}], ";"}], 
       "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Extract", " ", "the", " ", "time", " ", "value"}], "*)"}], "\n", 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Convert", " ", "time", " ", "to", " ", "minutes"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"timeInMinutes", "=", 
     RowBox[{"time", "/", "60"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Display", " ", "time", " ", "difference"}], "*)"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Total time for generating DensityPlot and Plot3D: \>\"", ",",
      "timeInMinutes", ",", "\"\< minutes\>\""}], "]"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Display", " ", "plots"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", "densityPlot", "]"}]}]}]], "Input",
